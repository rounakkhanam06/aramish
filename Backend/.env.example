# Port to run the server on
PORT=5000

# Environment mode (development, staging, production)
ENV=development

# MongoDB Connection String
MONGODB_URL=mongodb://localhost:27017/mynzo

# JWT Secret keys (Must be strong random strings in production)
JWT_SECRET=your_jwt_user_secret_key_change_me
JWT_ADMIN_SECRET=your_jwt_admin_secret_key_change_me

# Static OTP configuration (used for local/sandbox testing only)
STATIC_OTP=123456
# Comma-separated list of phone numbers allowed to use STATIC_OTP in staging/development.
# If left empty, all phone numbers can receive the static OTP in staging.
TEST_PHONE_NUMBERS=1111111111,2222222222

# Backend application URL
BACKEND_URL=http://localhost:5000

# SMS India Hub Configuration (Used in production)
SMS_API_KEY=your_sms_india_hub_api_key
SMS_SENDER_ID=IIDMTB
SMS_PE_ID=your_sms_pe_id
SMS_TEMPLATE_ID=your_sms_template_id

# Shiprocket Integration Credentials
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_API_BASE=https://apiv2.shiprocket.in
SHIPROCKET_WEBHOOK_SECRET=your_shiprocket_webhook_secret

# Razorpay credentials for payment & refund integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Firebase Service Account Credentials (Single-line JSON string)
# Optional: Can be loaded from here instead of Config/firebase-service-account.json
# Example: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT=
